<main class="research-app">
  <section class="hero-card">
    <p class="eyebrow">研究 × Webアプリ</p>
    <h1><%= @title %></h1>
    <p class="lead"><%= @subtitle %></p>

    <div class="research-notes">
      <h2>このデモでできること</h2>
      <ul>
        <% @research_points.each do |point| %>
          <li><%= point %></li>
        <% end %>
      </ul>
    </div>
  </section>

  <section class="workspace-card">
    <div class="controls">
      <label class="file-control">
        <span>画像を選択</span>
        <input id="imageInput" type="file" accept="image/*">
      </label>

      <label>
        分割数
        <select id="gridSize">
          <option value="3">3 × 3</option>
          <option value="4" selected>4 × 4</option>
          <option value="5">5 × 5</option>
          <option value="6">6 × 6</option>
        </select>
      </label>

      <button id="sampleButton" type="button">絵画サンプルを読み込む</button>
      <button id="shuffleButton" type="button">シャッフル</button>
      <button id="solveButton" type="button">元に戻す</button>
    </div>

    <div class="canvas-wrap">
      <canvas id="puzzleCanvas" width="640" height="640" aria-label="パズル描画キャンバス"></canvas>
    </div>

    <p class="hint">
      黒いマスが空白です。空白と同じ行・列にあるピースをクリックすると、間のピースがまとめてスライドします。
      これは puzzle-Processing 側の「空白マスを使って行・列をずらす」動きに寄せた試作版です。
    </p>
    <p id="sampleCredit" class="hint sample-credit"></p>
  </section>
</main>

<script>
(() => {
  const canvas = document.getElementById('puzzleCanvas');
  const ctx = canvas.getContext('2d');
  const imageInput = document.getElementById('imageInput');
  const gridSizeSelect = document.getElementById('gridSize');
  const sampleButton = document.getElementById('sampleButton');
  const shuffleButton = document.getElementById('shuffleButton');
  const solveButton = document.getElementById('solveButton');
  const sampleCredit = document.getElementById('sampleCredit');

  const sampleArtworks = [
    {
      title: '葛飾北斎「神奈川沖浪裏」',
      url: 'https://commons.wikimedia.org/wiki/Special:FilePath/Tsunami_by_hokusai_19th_century.jpg',
      credit: 'サンプル画像: 葛飾北斎「神奈川沖浪裏」 / Wikimedia Commons'
    },
    {
      title: 'フィンセント・ファン・ゴッホ「星月夜」',
      url: 'https://commons.wikimedia.org/wiki/Special:FilePath/Van_Gogh_-_Starry_Night_-_Google_Art_Project.jpg',
      credit: 'サンプル画像: フィンセント・ファン・ゴッホ「星月夜」 / Wikimedia Commons'
    }
  ];

  const state = {
    image: null,
    gridSize: Number(gridSizeSelect.value),
    pieces: [],
    blankIndex: 0,
    steps: 0
  };

  function totalPieces() {
    return state.gridSize * state.gridSize;
  }

  function buildPieces(size) {
    state.gridSize = size;
    const total = totalPieces();
    state.pieces = Array.from({ length: total }, (_, index) => index);
    state.pieces[total - 1] = null;
    state.blankIndex = total - 1;
    state.steps = 0;
  }

  function drawPlaceholder() {
    const size = canvas.width;
    ctx.clearRect(0, 0, size, size);
    const cell = size / state.gridSize;

    for (let y = 0; y < state.gridSize; y += 1) {
      for (let x = 0; x < state.gridSize; x += 1) {
        const hue = 210 + x * 12 + y * 8;
        ctx.fillStyle = `hsl(${hue}, 70%, ${55 + ((x + y) % 2) * 10}%)`;
        ctx.fillRect(x * cell, y * cell, cell, cell);
      }
    }

    ctx.fillStyle = 'rgba(255, 255, 255, 0.92)';
    ctx.fillRect(size * 0.12, size * 0.40, size * 0.76, size * 0.20);
    ctx.fillStyle = '#1f2937';
    ctx.font = 'bold 28px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('研究パズル Web デモ', size / 2, size / 2 - 10);
    ctx.font = '16px sans-serif';
    ctx.fillText('画像を選ぶか、絵画サンプルを読み込んでください', size / 2, size / 2 + 26);

    drawGrid();
  }

  function drawGrid() {
    const size = canvas.width;
    const cell = size / state.gridSize;
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.85)';
    ctx.lineWidth = 2;
    for (let i = 0; i <= state.gridSize; i += 1) {
      ctx.beginPath();
      ctx.moveTo(i * cell, 0);
      ctx.lineTo(i * cell, size);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(0, i * cell);
      ctx.lineTo(size, i * cell);
      ctx.stroke();
    }
  }

  function drawBlankCell(index, cell) {
    const x = (index % state.gridSize) * cell;
    const y = Math.floor(index / state.gridSize) * cell;
    ctx.fillStyle = '#111827';
    ctx.fillRect(x, y, cell, cell);
    ctx.fillStyle = '#ffffff';
    ctx.font = `${Math.max(14, cell * 0.18)}px sans-serif`;
    ctx.textAlign = 'center';
    ctx.fillText('空白', x + cell / 2, y + cell / 2 + 5);
  }

  function drawPuzzle() {
    const size = canvas.width;
    const grid = state.gridSize;
    const cell = size / grid;
    ctx.clearRect(0, 0, size, size);

    if (!state.image) {
      drawPlaceholder();
      return;
    }

    const imageSide = Math.min(state.image.width, state.image.height);
    const sourceX = (state.image.width - imageSide) / 2;
    const sourceY = (state.image.height - imageSide) / 2;
    const sourceCell = imageSide / grid;

    state.pieces.forEach((sourceIndex, displayIndex) => {
      if (sourceIndex === null) {
        drawBlankCell(displayIndex, cell);
        return;
      }

      const sx = (sourceIndex % grid) * sourceCell + sourceX;
      const sy = Math.floor(sourceIndex / grid) * sourceCell + sourceY;
      const dx = (displayIndex % grid) * cell;
      const dy = Math.floor(displayIndex / grid) * cell;
      ctx.drawImage(state.image, sx, sy, sourceCell, sourceCell, dx, dy, cell, cell);
    });

    drawGrid();
  }

  function isSameRowOrColumn(indexA, indexB) {
    return Math.floor(indexA / state.gridSize) === Math.floor(indexB / state.gridSize) ||
      indexA % state.gridSize === indexB % state.gridSize;
  }

  function slideToBlank(clickedIndex) {
    if (clickedIndex === state.blankIndex) return;
    if (!isSameRowOrColumn(clickedIndex, state.blankIndex)) return;

    const grid = state.gridSize;
    const clickedX = clickedIndex % grid;
    const clickedY = Math.floor(clickedIndex / grid);
    const blankX = state.blankIndex % grid;
    const blankY = Math.floor(state.blankIndex / grid);

    if (clickedY === blankY) {
      const step = clickedX < blankX ? 1 : -1;
      for (let x = blankX; x !== clickedX; x -= step) {
        const from = blankY * grid + (x - step);
        const to = blankY * grid + x;
        state.pieces[to] = state.pieces[from];
      }
    } else {
      const step = clickedY < blankY ? 1 : -1;
      for (let y = blankY; y !== clickedY; y -= step) {
        const from = (y - step) * grid + blankX;
        const to = y * grid + blankX;
        state.pieces[to] = state.pieces[from];
      }
    }

    state.pieces[clickedIndex] = null;
    state.blankIndex = clickedIndex;
    state.steps += Math.abs(clickedX - blankX) + Math.abs(clickedY - blankY);
    drawPuzzle();
  }

  function inversionCount(values) {
    let count = 0;
    for (let i = 0; i < values.length; i += 1) {
      for (let j = i + 1; j < values.length; j += 1) {
        if (values[i] > values[j]) count += 1;
      }
    }
    return count;
  }

  function isSolvable(pieces, blankIndex) {
    const grid = state.gridSize;
    const values = pieces.filter((piece) => piece !== null);
    const inv = inversionCount(values);

    if (grid % 2 === 1) return inv % 2 === 0;

    const blankRowFromBottom = grid - Math.floor(blankIndex / grid);
    return (blankRowFromBottom % 2 === 0) !== (inv % 2 === 0);
  }

  function shufflePieces() {
    const total = totalPieces();
    let pieces;
    let blankIndex;

    do {
      pieces = Array.from({ length: total }, (_, index) => index);
      pieces[total - 1] = null;
      for (let i = pieces.length - 1; i > 0; i -= 1) {
        const j = Math.floor(Math.random() * (i + 1));
        [pieces[i], pieces[j]] = [pieces[j], pieces[i]];
      }
      blankIndex = pieces.indexOf(null);
    } while (!isSolvable(pieces, blankIndex));

    state.pieces = pieces;
    state.blankIndex = blankIndex;
    state.steps = 0;
    drawPuzzle();
  }

  function solvePieces() {
    buildPieces(state.gridSize);
    drawPuzzle();
  }

  function loadImageFromUrl(url, onload) {
    const img = new Image();
    img.onload = () => onload(img);
    img.onerror = () => {
      sampleCredit.textContent = 'サンプル画像の読み込みに失敗しました。別の画像を選択してください。';
    };
    img.src = url;
  }

  function loadSampleArtwork() {
    const artwork = sampleArtworks[Math.floor(Math.random() * sampleArtworks.length)];
    sampleCredit.textContent = `${artwork.title} を読み込み中...`;
    loadImageFromUrl(artwork.url, (img) => {
      state.image = img;
      buildPieces(Number(gridSizeSelect.value));
      shufflePieces();
      sampleCredit.textContent = artwork.credit;
    });
  }

  imageInput.addEventListener('change', (event) => {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        state.image = img;
        buildPieces(Number(gridSizeSelect.value));
        shufflePieces();
        sampleCredit.textContent = 'サンプル画像ではなく、選択した画像を使用しています。';
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });

  gridSizeSelect.addEventListener('change', () => {
    buildPieces(Number(gridSizeSelect.value));
    if (state.image) shufflePieces();
    else drawPuzzle();
  });

  canvas.addEventListener('click', (event) => {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const x = (event.clientX - rect.left) * scaleX;
    const y = (event.clientY - rect.top) * scaleY;
    const cell = canvas.width / state.gridSize;
    const index = Math.floor(y / cell) * state.gridSize + Math.floor(x / cell);
    slideToBlank(index);
  });

  sampleButton.addEventListener('click', loadSampleArtwork);
  shuffleButton.addEventListener('click', shufflePieces);
  solveButton.addEventListener('click', solvePieces);

  buildPieces(state.gridSize);
  drawPlaceholder();
})();
</script>
